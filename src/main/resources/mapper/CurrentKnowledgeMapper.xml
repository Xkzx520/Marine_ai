<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.springboot.marine_ai.mapper.CurrentKnowledgeMapper">
    <select id="selectAll" resultType="com.springboot.marine_ai.entity.CurrentKnowledge">
        SELECT id, title, content, sort, create_time AS createTime
        FROM t_current_knowledge
        ORDER BY sort, id
    </select>
</mapper>